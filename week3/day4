//exersice5
// 1. Function Declaration (Hoisted)
function convertToGrams(kg) {
    return kg * 1000;
}
console.log(convertToGrams(2));

// 2. Function Expression (Not hoisted)
const kgToGrams = function(kg) {
    return kg * 1000;
};
console.log(kgToGrams(3));

// Difference: Function declarations are hoisted to the top of the script; function expressions are not.

// 3. Arrow Function
const arrowKgToGrams = kg => kg * 1000;
console.log(arrowKgToGrams(4));

