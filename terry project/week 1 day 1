#exercise8
# Setting my name
my_name = "Teresia"

# Asking the user for their name
user_name = input("What is your name? ")

# Comparing the names (using .lower() to ignore capitalization)
if user_name.strip().lower() == my_name.lower():
    print(f"Wait... your name is {user_name} too? There can only be one. Choose your weapon!")
else:
    print(f"Phew! {user_name} is a nice name, but it's no {my_name}. We can still be friends.")

