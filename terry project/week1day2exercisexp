attendees = []

# Ask how many people
num_people = int(input("How many people are in the group? "))

# Collect ages
for i in range(num_people):
    age = int(input(f"Enter age of person {i+1}: "))
    attendees.append(age)

# Filter allowed ages (16–21 inclusive)
allowed = []

