def longest_word(sentence):
    # Step 2: Split the sentence into words
    words = sentence.split()
    
    # Step 3: Initialize variable
    longest = ""
    
    # Step 4 & 5: Loop and compare lengths
    for word in words:
        if len(word) > len(longest):
            longest = word
    
    # Step 6: Return result
    return longest
