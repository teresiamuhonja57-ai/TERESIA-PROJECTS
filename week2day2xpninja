import time
import os

class GameOfLife:
    def __init__(self, rows, cols, initial_state=None):
        self.rows = rows
        self.cols = cols
        # Initialize grid with 0 (dead)
        self.grid = [[0 for _ in range(cols)] for _ in range(rows)]
        
        if initial_state:
            self.apply_initial_state(initial_state)

    def apply_initial_state(self, state):
        """Sets the starting live cells."""
        for r, c in state:
            if 0 <= r < self.rows and 0 <= c < self.cols:
                self.grid[r][c] = 1

    def count_neighbors(self, r, c):
        """Counts live neighbors in a 3x3 area around the cell."""
        count = 0
        for i in range(-1, 2):
            for j in range(-1, 2):
                if i == 0 and j == 0:
                    continue
                
                neighbor_r, neighbor_c = r + i, c + j
                
                # Check boundaries (Fixed Border logic)
                if 0 <= neighbor_r < self.rows and 0 <= neighbor_c < self.cols:
                    count += self.grid[neighbor_r][neighbor_c]
        return count

    def next_generation(self):
        """Calculates the next state of the entire grid."""
        new_grid = [[0 for _ in range(self.cols)] for _ in range(self.rows)]
        
        for r in range(self.rows):
            for c in range(self.cols):
                neighbors = self.count_neighbors(r, c)
                
                if self.grid[r][c] == 1:
                    # Survival rules
                    if neighbors == 2 or neighbors == 3:
                        new_grid[r][c] = 1
                else:
                    # Reproduction rule
                    if neighbors == 3:
                        new_grid[r][c] = 1
        
        self.grid = new_grid

    def display(self):
        """Renders the grid to the console."""
        os.system('cls' if os.name == 'nt' else 'clear')
        for row in self.grid:
            print("".join([" █ " if cell else " . " for cell in row]))
        print("\nPress Ctrl+C to stop.")

# Example Usage:
if __name__ == "__main__":
    # A "Glider" pattern
    glider = [(1, 2), (2, 3), (3, 1), (3, 2), (3, 3)]
    
    game = GameOfLife(15, 15, initial_state=glider)
    
    try:
        while True:
            game.display()
            game.next_generation()
            time.sleep(0.2)
    except KeyboardInterrupt:
        print("Game Over.")
